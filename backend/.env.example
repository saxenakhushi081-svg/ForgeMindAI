# ForgeMind AI Backend Environment Variables
# Copy this file to .env and fill in your values

# Database (provided by Replit)
DATABASE_URL=postgresql://user:password@localhost:5432/forgemind

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Server
PORT=8080

# File storage
UPLOAD_DIR=/tmp/forgemind_uploads
FAISS_DIR=/tmp/forgemind_faiss
